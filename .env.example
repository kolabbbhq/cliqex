# ============================================================
# ErrandsBuddy API — Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to git
# ============================================================

# ---- Database ----
DATABASE_URL="postgresql://postgres:password@localhost:5432/errandsbuddy?schema=public"

# ---- App ----
PORT=3000
NODE_ENV=development

# ---- JWT ----
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# ---- WhatsApp (Meta Cloud API) ----
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_ACCESS_TOKEN=your-whatsapp-access-token
WHATSAPP_VERIFY_TOKEN=your-custom-webhook-verify-token   # you choose this
WHATSAPP_API_VERSION=v19.0

# ---- Paystack ----
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx

# ---- AWS S3 (for media storage) ----
AWS_ACCESS_KEY_ID=your-aws-access-key
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_REGION=eu-west-1
AWS_S3_BUCKET=errandsbuddy-media

# ---- Redis (for BullMQ queues) ----
REDIS_HOST=localhost
REDIS_PORT=6379

# ---- AI (for image extraction & price suggestions) ----
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxx
# or use Anthropic:
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx
